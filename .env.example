# ========================================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# Copy this file to .env and fill in your actual credentials and settings
# ========================================================================================

# ----------------------------------------------------------------------------------------
# AWS Credentials & Region Configuration
# ----------------------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1
# AWS_PROFILE=default

# ----------------------------------------------------------------------------------------
# S3 Storage Configuration
# ----------------------------------------------------------------------------------------
# S3_BUCKET=credit-card-fraud-data-bucket
# S3_KMS_KEY_ARN=arn:aws:s3:::credit-card-fraud-data-bucket
# FORCE_S3_IO=true

# ----------------------------------------------------------------------------------------
# MLflow Tracking Configuration
# ----------------------------------------------------------------------------------------
# MLFLOW_TRACKING_URI=http://mlflow-tracking:5001
# MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://${S3_BUCKET}/mlflow-artifacts

# ----------------------------------------------------------------------------------------
# AWS RDS PostgreSQL Configuration (Metadata Storage for MLflow & Airflow)
# ----------------------------------------------------------------------------------------
# RDS_HOST=your-rds-instance.xxxxxx.us-east-1.rds.amazonaws.com
# RDS_PORT=5432
# RDS_USER=postgres
# RDS_PASSWORD=your_secure_db_password
# RDS_AIRFLOW_DB=airflow
# RDS_MLFLOW_DB=mlflow
# MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://${RDS_USER}:${RDS_PASSWORD}@${RDS_HOST}:${RDS_PORT}/${RDS_MLFLOW_DB}

# ----------------------------------------------------------------------------------------
# Apache Airflow Configuration
# ----------------------------------------------------------------------------------------
# AIRFLOW_UID=50000
# AIRFLOW_HOME=/opt/airflow

# ----------------------------------------------------------------------------------------
# Docker & Pipeline Settings
# ----------------------------------------------------------------------------------------
# COMPOSE_PROJECT_NAME=ml-pipeline
# DOCKER_BUILDKIT=1
# PYTHONUNBUFFERED=1
# PYTHONDONTWRITEBYTECODE=1
